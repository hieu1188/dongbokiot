# ============================================================
#  CẤU HÌNH ĐỒNG BỘ TỒN KHO KIOTVIET 1 <-> KIOTVIET 2
#  Copy file này thành ".env" rồi điền thông tin thật.
# ============================================================

# --- Tài khoản KiotViet 1 (CHÍNH: TikTok + Shopee + bán quầy) ---
KV1_NAME=CHINH
KV1_RETAILER=ten_gian_hang_1
KV1_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KV1_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# BranchId của kho vật lý dùng chung, trong tài khoản 1 (số nguyên).
KV1_BRANCH_ID=0

# --- Tài khoản KiotViet 2 (PHỤ: tệp khách riêng) ---
KV2_NAME=PHU
KV2_RETAILER=ten_gian_hang_2
KV2_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KV2_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# BranchId của kho vật lý dùng chung, trong tài khoản 2 (số nguyên).
KV2_BRANCH_ID=0

# --- Bảo mật webhook ---
# (1) Secret nằm trong URL webhook: /webhook/<WEBHOOK_SECRET>. Ai không biết -> 403.
WEBHOOK_SECRET=doi_chuoi_nay_thanh_mot_chuoi_ngau_nhien_dai

# (2) Secret để KiotViet KÝ chữ ký X-Hub-Signature (HMAC-SHA256) cho TỪNG tài khoản.
#     Để TRỐNG -> chạy register_webhooks.py sẽ tự sinh và in ra cho bạn dán vào đây.
#     Giá trị này phải GIỐNG NHAU giữa lúc đăng ký và lúc server kiểm tra.
KV1_WEBHOOK_SIGN_SECRET=
KV2_WEBHOOK_SIGN_SECRET=

# --- Địa chỉ công khai của server (điền sau khi có VPS/tunnel) ---
# Ví dụ: https://sync.tenmiencuaban.com  hoặc  https://abcd-1234.ngrok-free.app
PUBLIC_URL=https://doi-thanh-dia-chi-that

# --- CHẾ ĐỘ AN TOÀN ---
# true  = CHỈ ghi log, KHÔNG thật sự sửa tồn (để test trước cho chắc).
# false = ghi tồn thật vào KiotViet.
DRY_RUN=true

# Tự động tạo sản phẩm sang tài khoản kia khi có mã hàng mới (true/false).
# true  = thêm hàng ở KV1 xong, server tự tạo bản sao sang KV2.
# false = bạn tự tạo sản phẩm ở cả 2 tài khoản.
AUTO_CREATE_PRODUCT=true

# Cổng server lắng nghe
PORT=8000

# --- DEBOUNCE: chống drift do webhook TRỄ + DỒN CỤC (SP đa đơn vị/biến thể) ---
# KiotViet bắn webhook theo cục (dồn event trễ đẩy một lúc) -> event mã anh em đến
# lộn thứ tự -> ghi số cũ đè số mới. Bật debounce: hoãn tới khi cục lắng rồi ghi 1 lần
# với giá trị mới nhất, và đọc lại tồn thật từ nguồn. true = bật (khuyến nghị).
DEBOUNCE_ENABLED=true
# Đợi bao lâu sau event CUỐI của một mã rồi mới ghi (giây). Mỗi event mới reset lại.
DEBOUNCE_SECONDS=8
# Trần chờ tối đa kể từ event ĐẦU (tránh chờ vô tận khi cục webhook kéo dài).
DEBOUNCE_MAX_HOLD=30
# Lúc ghi, ĐỌC LẠI tồn thật từ tài khoản nguồn thay vì tin giá trị trong webhook
# (lớp chống drift chính khi webhook trễ). true = bật.
RESYNC_READ_SOURCE=true

# --- GỘP GHI SP đa đơn vị (giảm phiếu cân bằng kho thừa) ---
# 1 giao dịch SP đa đơn vị làm nhiều mã cùng SP cha đổi tồn -> nhiều phiếu. Ghi 1 mã là
# KiotViet tự cập nhật mã anh em (chung kho), nên trong cửa sổ dưới đây chỉ ghi 1 lần,
# mã anh em còn lại bỏ qua -> giảm nửa phiếu. true = bật.
MULTIUNIT_COLLAPSE=true
MULTIUNIT_COLLAPSE_WINDOW=25

# --- CẢNH BÁO SỚM: 1 mã đồng bộ liên tục quá nhiều lần trong thời gian ngắn ---
# Nghi đồng bộ ngược/loop chớm: 1 mã bị GHI quá RAPID_SYNC_MAX lần trong RAPID_SYNC_WINDOW
# giây -> cảnh báo NGAY (không dừng sync, chỉ báo để kiểm sớm).
RAPID_SYNC_WINDOW=180
RAPID_SYNC_MAX=2
RAPID_SYNC_COOLDOWN=30

# ============================================================
#  CẢNH BÁO & CHỐNG OVERSELL KHI SERVER CHẾT
# ============================================================
# Telegram để nhận cảnh báo (server chết/sống lại, kết quả reconcile).
# Để TRỐNG -> hệ thống chỉ in log, không gửi. Cách lấy:
#   1) Nhắn @BotFather -> /newbot -> lấy TOKEN.
#   2) Nhắn cho bot 1 câu, mở https://api.telegram.org/bot<TOKEN>/getUpdates -> lấy chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Nhịp tim + ngưỡng phát hiện server vừa chết một đoạn (giây).
HEARTBEAT_SECONDS=60
DOWNTIME_ALERT_SECONDS=300

# Định kỳ (phút) kiểm webhook còn active không; bị KiotViet tắt -> tự bật lại + báo.
# 0 = tắt việc tự kiểm.
WEBHOOK_CHECK_MINUTES=10

# --- KIỂM NHẤT QUÁN định kỳ (bắt "drift âm thầm" KV1 != KV2) ---
# Cứ mỗi N phút, soi các mã VỪA có giao dịch xem KV1 có = KV2 không; lệch -> cảnh báo
# Telegram kèm link /fix. Vá lỗ hổng: loop quá ngắn thì bộ chống loop không kịp báo.
# 0 = tắt.
CONSISTENCY_CHECK_MINUTES=15
# Soi các mã có giao dịch trong bao nhiêu giờ gần nhất.
CONSISTENCY_LOOKBACK_HOURS=3
# Chênh lệch KV1-KV2 lớn hơn số này mới coi là lệch (bỏ sai số làm tròn cực nhỏ).
CONSISTENCY_TOLERANCE=0.01
# Không báo lại CÙNG một mã trong bao nhiêu phút (chống spam).
CONSISTENCY_ALERT_COOLDOWN=120
# KIỂM TỨC THÌ sau MỖI lần sync: ghi xong -> đợi vài giây -> đọc lại KV1/KV2, còn lệch
# thì cảnh báo NGAY (không đợi nhịp quét định kỳ). true = bật.
CONSISTENCY_VERIFY_ON_SYNC=true
# Đợi bao lâu sau khi sync ghi xong rồi mới kiểm (giây) — đủ để SP đa đơn vị lắng.
CONSISTENCY_VERIFY_DELAY=15

# --- QUÉT TOÀN KHO định kỳ (so TẤT CẢ mã 2 KV) ---
# Mỗi N giờ, quét toàn bộ tồn KV1+KV2, so mọi mã, báo cáo chi tiết mã lệch qua Telegram
# + lưu để xem ở trang /drift/<WEBHOOK_SECRET>. Bắt cả drift không qua webhook. 0 = tắt.
FULL_CHECK_HOURS=2
# Số mã lệch tối đa liệt kê trong tin Telegram (còn lại xem ở trang /drift).
FULL_REPORT_MAX=25

# Tên khách hàng "nội bộ" (điều chuyển giữa 2 gian) — reconcile KHÔNG tính là bán ra.
# Ngăn cách bằng dấu phẩy. Ví dụ: INTERNAL_CUSTOMERS=Kho tong,Dieu chuyen
INTERNAL_CUSTOMERS=

# ============================================================
#  BỘ CHẠY ĐỊNH KỲ (scheduler): chụp tồn + reconcile lưới an toàn
# ============================================================
# Bật scheduler chạy nền trong server (true/false).
ENABLE_SCHEDULER=false
# Chụp toàn bộ tồn KV1+KV2 ra file JSON mỗi N giờ (0 = tắt). Giữ tối đa SNAPSHOT_KEEP bản.
SNAPSHOT_EVERY_HOURS=6
SNAPSHOT_KEEP=60
# Thư mục lưu snapshot (nên cùng chỗ với DB để cùng sống trên Railway Volume).
SNAPSHOT_DIR=snapshots
# Reconcile định kỳ mỗi ngày lúc mấy giờ (giờ VN "HH:MM"; để trống = tắt). Vd 02:00
RECONCILE_AT=
# Gửi tóm tắt hoạt động cuối ngày vào Telegram lúc mấy giờ (giờ VN "HH:MM"; trống = tắt). Vd 21:00
DAILY_SUMMARY_AT=
# false = chỉ CHECK + cảnh báo (an toàn). true = tự ghi lệch trong ngưỡng bên dưới.
RECONCILE_AUTO_APPLY=false
# Lệch 1 mã lớn hơn số này -> KHÔNG tự ghi, chỉ cảnh báo.
RECONCILE_MAX_CHANGE=200
